# LLM + MCP (shared with ReAct/)
GEMINI_API_KEY=
# Reviewer (ReAct) + Fixer — larger model
GEMINI_MODEL=gemini-2.0-flash

# Init + Pusher — small / cheap models (SLM tier)
# Recommended: gemini-2.5-flash-lite (migrate before gemini-2.0-* deprecation)
GEMINI_MODEL_INIT=gemini-2.5-flash-lite
GEMINI_MODEL_PUSHER=gemini-2.5-flash-lite
# Set false to skip SLM calls (init uses MCP only; pusher uses template)
ORCH_USE_SLM=true

# MCP (default: self-hosted github-mcp-server on localhost; uses GITHUB_TOKEN as Bearer)
MCP_SERVER_URL=http://localhost:8000
GITHUB_TOKEN=

# Orchestration knobs
ORCH_MAX_ITERATIONS=5
# Comma-separated severities the fixer will attempt to address.
ORCH_FIX_SEVERITIES=blocking,major

# Tester (CI poll) settings
ORCH_TESTER_TIMEOUT=600                   # seconds to wait for GitHub Actions runs

# Checkpoint (resume-on-crash) — SQLite file path
ORCH_CHECKPOINT_DB=.orchestration_state.db
