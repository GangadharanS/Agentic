# RAG mode: local (ChromaDB + Ollama) or cloud (Pinecone + Groq/Gemini)
RAG_MODE=local

# --- Local mode (default) ---
# Ollama runs on the host; Docker connects via host.docker.internal
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=600

# --- Cloud mode (Option A) ---
# Get a free Pinecone key: https://app.pinecone.io/
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rag-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# If true, delete and recreate the Pinecone index automatically when its
# dimension doesn't match the active embedding provider (data loss + re-ingest).
PINECONE_AUTO_RECREATE_INDEX=true

# Get a free Groq key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional: use Gemini instead of Groq (set LLM_PROVIDER=gemini)
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_PROVIDER=groq

# --- Embeddings ---
# local  = sentence-transformers all-MiniLM-L6-v2 (384 dims, runs in container, ~600 MB lazy install)
# gemini = Google gemini-embedding-001 (default 3072 dims, free cloud — needs GEMINI_API_KEY)
#         Matryoshka: set EMBEDDING_DIMENSION=768 or 1536 for smaller vectors (zero quality loss for 768).
# NOTE: text-embedding-004 was retired on Jan 14, 2026 and returns 404 — use gemini-embedding-001.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Leave EMBEDDING_DIMENSION blank to auto-detect from provider:
#   local  -> 384, gemini-embedding-001 -> 3072 (or set 768 / 1536 explicitly)
EMBEDDING_DIMENSION=
