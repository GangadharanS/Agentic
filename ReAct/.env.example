# ReAct PR Review - client config

# --- MCP server (GitHub's official MCP server, Streamable HTTP) ---
# Option A: self-host github-mcp-server (recommended).
#   docker rm -f github-mcp 2>/dev/null
#   docker run -d --name github-mcp -p 8000:8082 \
#     -e GITHUB_PERSONAL_ACCESS_TOKEN=$GITHUB_TOKEN \
#     ghcr.io/github/github-mcp-server:latest http --port 8082
#   MCP_SERVER_URL=http://localhost:8000
#   Health check: curl -X POST http://localhost:8000/mcp -H "Authorization: Bearer $GITHUB_TOKEN" ...
#   (GET /sse returns 405 — that is normal; the server uses POST /mcp, not /sse)
#
# Option B: GitHub-hosted remote MCP (requires Copilot on most endpoints).
#   MCP_SERVER_URL=https://api.githubcopilot.com/mcp/
#
MCP_SERVER_URL=http://localhost:8000
MCP_AUTH_TOKEN=
# streamable (default, github-mcp-server v1+) | sse (legacy custom mcp_client_app)
MCP_TRANSPORT=streamable

# --- Gemini (cloud LLM, free via Google AI Studio) ---
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- GitHub token for the UI backend ---
# Used by github_api.py to list repos/PRs and (when MCP_AUTH_TOKEN is empty
# and MCP_SERVER_URL points at api.githubcopilot.com) as the MCP auth token.
# Scope: `repo` for private repos, `public_repo` for public-only.
GITHUB_TOKEN=

# --- UI backend ---
REACT_BACKEND_PORT=8090
REACT_MAX_ROUNDS=8
